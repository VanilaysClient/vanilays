// ── TOAST ──
var toastTimer=null;
function showToast(msg,type){
  var t=document.getElementById("toast");
  t.innerHTML=msg;
  t.className=type;
  t.style.display="block";t.style.opacity="1";
  if(toastTimer) clearTimeout(toastTimer);
  toastTimer=setTimeout(function(){
    t.style.opacity="0";
    setTimeout(function(){t.style.display="none";},500);
  },4000);
}

// ── AUTH STATE (заменяет старую сессию из localStorage) ──
onAuthStateChanged(auth, async function(fbUser){
  if(!fbUser){
    currentUser=null;
    document.getElementById("navAuth").style.display="flex";
    document.getElementById("navProfile").style.display="none";
    document.getElementById("authGate").style.display="block";
    return;
  }
  var snap;
  try{
    snap=await getDoc(doc(db,"users",fbUser.uid));
  }catch(e){
    return;
  }
  if(!snap.exists()){
    await signOut(auth);
    return;
  }
  var profile=snap.data();
  if(profile.banned){
    await signOut(auth);
    showToast("Аккаунт заблокирован. Обратись в поддержку.","err");
    return;
  }
  currentUser=Object.assign({uid:fbUser.uid}, profile);
  document.getElementById("navAuth").style.display="none";
  document.getElementById("navProfile").style.display="flex";
  document.getElementById("navUsername").textContent=currentUser.username;
  document.getElementById("navUsername2").textContent=currentUser.username;
  document.getElementById("authGate").style.display="none";
  refreshProfile();
});

