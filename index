function prizeIconSVG(type){ return PRIZE_ICONS[type]||PRIZE_ICONS.nothing; }

function applyPrize(prize){
  var resEl=document.getElementById("prizeResult");
  resEl.style.display="block";
  if(prize.type==="nothing"){
    resEl.style.color="rgba(255,255,255,.5)";
    resEl.textContent="Увы, в этот раз пусто. Попробуй завтра!";
    return;
  }
  if(prize.type==="promo30"){
    var code=genPromoCode();
    currentUser.wonPromoCode=code;
    currentUser.wonPromoDiscount=0.3;
    resEl.style.color="#ffcf6b";
    resEl.textContent="Промокод на -30%: "+code+" (сохрани его для оплаты)";
  } else if(prize.type==="day1"){
    grantSubscription(currentUser,1,currentUser.subLabel||"+1 день");
    resEl.style.color="#ffcf6b";
    resEl.textContent="Начислен +1 день подписки!";
  } else if(prize.type==="sub7"){
    grantSubscription(currentUser,7,"7 дней");
    resEl.style.color="#ffcf6b";
    resEl.textContent="Начислена подписка на 7 дней!";
  } else if(prize.type==="forever"){
    grantSubscription(currentUser,999999,"Навсегда");
    resEl.style.color="#ffcf6b";
    resEl.textContent="Джекпот! Подписка навсегда активирована!";
  } else if(prize.type==="beta"){
    currentUser.beta=true;
    resEl.style.color="#ffcf6b";
    resEl.textContent="Невероятная удача! Доступ в закрытый бета-тест открыт.";
  }
  refreshProfile();
  launchConfetti();
}


var buyData={price:0,basePrice:0,name:"",desc:"",method:"",promoApplied:false};
var PROMOS={"SUMMER2026":0.15};

function tryBuy(name,desc,price){
  if(!currentUser){
    // Highlight auth gate and scroll to products
    document.getElementById("authGate").style.display="block";
    document.getElementById("authGate").style.animation="none";
    document.getElementById("authGate").style.border="1px solid rgba(74,172,255,.5)";
    document.getElementById("sectionProducts").scrollIntoView({behavior:"smooth"});
    setTimeout(function(){document.getElementById("authGate").style.border="1px solid rgba(74,172,255,.2)";},1500);
    openModal("login");
    return;
  }
  openBuy(name,desc,price);
}

function openBuy(name,desc,price){
  buyData={price:price,basePrice:price,name:name,desc:desc,method:"",promoApplied:false};
  document.getElementById("buyProductName").textContent=name;
  document.getElementById("buyProductDesc").textContent=desc;
  document.getElementById("buyPromoInput").value="";
  document.getElementById("buyPromoOk").style.display="none";
  document.getElementById("buyPromoErr").style.display="none";
  document.getElementById("buyPriceFinal").textContent=price+" ₽";
  document.getElementById("buyPriceOld").style.display="none";
  document.getElementById("buyDiscBadge").style.display="none";
  document.querySelectorAll(".pay-btn").forEach(function(b){b.classList.remove("selected");});
  document.getElementById("buyConfirmBtn").disabled=true;
  document.getElementById("buyModal").style.display="flex";
}
function closeBuyModal(){document.getElementById("buyModal").style.display="none";}

function selectPay(m){
  buyData.method=m;
  document.querySelectorAll(".pay-btn").forEach(function(b){b.classList.remove("selected");});
  document.getElementById("pay-"+m).classList.add("selected");
  document.getElementById("buyConfirmBtn").disabled=false;
}

function applyPromo(){
  var code=document.getElementById("buyPromoInput").value.trim().toUpperCase();
  var ok=document.getElementById("buyPromoOk"),err=document.getElementById("buyPromoErr");
  ok.style.display="none";err.style.display="none";
  if(buyData.promoApplied){err.textContent="Промокод уже применён";err.style.display="block";return;}
  var disc = PROMOS[code] || ((currentUser && currentUser.wonPromoCode===code) ? currentUser.wonPromoDiscount : undefined);
  if(!disc){err.textContent="Неверный промокод";err.style.display="block";return;}
  var np=Math.round(buyData.basePrice*(1-disc));
  buyData.price=np;buyData.promoApplied=true;
  document.getElementById("buyPriceFinal").textContent=np+" ₽";
  document.getElementById("buyPriceOld").textContent=buyData.basePrice+" ₽";
  document.getElementById("buyPriceOld").style.display="inline";
  document.getElementById("buyDiscBadge").textContent="-"+(disc*100)+"% скидка";
  document.getElementById("buyDiscBadge").style.display="inline-flex";
  ok.innerHTML=CHECK_SVG+"Скидка "+(disc*100)+"% применена";ok.style.display="block";
}

function confirmBuy(){
  var m=buyData.method==="funpay"?"FunPay":"Telegram Stars";
  closeBuyModal();
  launchConfetti();
  showToast(CHECK_SVG+"Оплата через "+m+" — "+buyData.price+" ₽ · Ключ придёт в Telegram","ok");
}

