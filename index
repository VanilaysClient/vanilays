<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Vanilays</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:"Inter",sans-serif;min-height:100vh;background:#060a14;color:#fff;overflow-x:hidden}

    .bg-img{position:fixed;inset:0;z-index:0;background:url("data:image/jpeg;base64,") center/cover no-repeat;animation:bgIn 1.4s ease both}
    @keyframes bgIn{from{opacity:0;transform:scale(1.05)}to{opacity:1;transform:scale(1)}}
    .bg-overlay{position:fixed;inset:0;z-index:1;background:linear-gradient(180deg,rgba(4,8,20,.62) 0%,rgba(6,12,28,.44) 45%,rgba(4,8,20,.80) 100%)}
    .particles{position:fixed;inset:0;z-index:2;pointer-events:none;overflow:hidden}
    .p{position:absolute;border-radius:50%;animation:floatUp linear infinite}
    @keyframes floatUp{0%{transform:translateY(0) translateX(0) scale(1);opacity:0}8%{opacity:1}92%{opacity:.2}100%{transform:translateY(-110vh) translateX(var(--d)) scale(.2);opacity:0}}

    .page{display:none;position:fixed;inset:0;overflow-y:auto;z-index:10}
    .page.active{display:block}

    /* NAV */
    nav{position:sticky;top:0;z-index:50;display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:64px;background:rgba(4,8,22,.58);backdrop-filter:blur(22px);border-bottom:1px solid rgba(74,172,255,.12);animation:slideDown .65s cubic-bezier(.22,1,.36,1) both}
    @keyframes slideDown{from{transform:translateY(-100%);opacity:0}to{transform:translateY(0);opacity:1}}
    .nav-logo{display:flex;align-items:center;gap:9px;font-weight:800;font-size:17px;color:#fff;text-decoration:none}
    .nav-logo svg{filter:drop-shadow(0 0 8px rgba(74,172,255,.7));transition:filter .3s}
    .nav-logo:hover svg{filter:drop-shadow(0 0 18px rgba(74,172,255,1))}
    .nav-links{display:flex;align-items:center;gap:28px;list-style:none}
    .nav-links a{color:rgba(255,255,255,.62);text-decoration:none;font-size:13.5px;font-weight:500;transition:color .2s,text-shadow .2s;cursor:pointer}
    .nav-links a:hover{color:#fff;text-shadow:0 0 14px rgba(74,172,255,.55)}
    .nav-actions{display:flex;align-items:center;gap:10px}
    .btn-nav{padding:7px 18px;border-radius:999px;font-size:13.5px;font-weight:600;cursor:pointer;transition:all .25s;border:none;font-family:"Inter",sans-serif}
    .btn-nav-outline{background:transparent;border:1px solid rgba(255,255,255,.22);color:rgba(255,255,255,.85)}
    .btn-nav-outline:hover{background:rgba(255,255,255,.1);color:#fff}
    .btn-nav-solid{background:linear-gradient(135deg,#4aacff,#2b7fff);color:#fff;box-shadow:0 0 22px rgba(74,172,255,.32)}
    .btn-nav-solid:hover{box-shadow:0 0 36px rgba(74,172,255,.6);transform:translateY(-1px)}
    .nav-profile{display:flex;align-items:center;gap:8px;background:rgba(74,172,255,.1);border:1px solid rgba(74,172,255,.25);border-radius:999px;padding:5px 14px 5px 6px;font-size:13.5px;font-weight:600;cursor:pointer;transition:all .25s}
    .nav-profile:hover{background:rgba(74,172,255,.2);box-shadow:0 0 18px rgba(74,172,255,.28)}
    .nav-profile img{width:30px;height:30px;border-radius:50%;border:1px solid rgba(74,172,255,.4)}

    /* SHOP */
    .shop{padding:96px 40px 60px;text-align:center}
    .shop-eyebrow{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(74,172,255,.8);margin-bottom:14px;animation:fadeUp .7s .25s both}
    .shop-title{font-size:clamp(38px,6vw,62px);font-weight:800;letter-spacing:-2px;line-height:1.05;margin-bottom:16px;background:linear-gradient(135deg,#fff 40%,rgba(74,172,255,.85));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:fadeUp .7s .4s both}
    .shop-sub{font-size:15px;color:rgba(255,255,255,.48);margin-bottom:68px;animation:fadeUp .7s .55s both}
    @keyframes fadeUp{from{transform:translateY(22px);opacity:0}to{transform:translateY(0);opacity:1}}

    .cards{display:flex;justify-content:center;gap:20px;flex-wrap:wrap}
    .card{width:240px;background:rgba(255,255,255,.07);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:28px 24px;display:flex;flex-direction:column;text-align:left;transition:border-color .3s,box-shadow .3s,background .3s;animation:fadeUp .7s both;position:relative;overflow:hidden;transform-style:preserve-3d;will-change:transform}
    .card::after{content:"";position:absolute;inset:-60% -60%;background:linear-gradient(105deg,transparent 40%,rgba(74,172,255,.09) 50%,transparent 60%);transform:translateX(-100%);transition:transform .65s ease}
    .card:hover::after{transform:translateX(100%)}
    .card:hover{border-color:rgba(74,172,255,.42);box-shadow:0 24px 64px rgba(0,0,0,.45),0 0 36px rgba(74,172,255,.14);background:rgba(255,255,255,.1)}
    .card:nth-child(1){animation-delay:.65s}.card:nth-child(2){animation-delay:.8s}.card:nth-child(3){animation-delay:.95s}.card:nth-child(4){animation-delay:1.1s}
    .card-icon{width:48px;height:48px;margin-bottom:20px;filter:drop-shadow(0 0 10px rgba(74,172,255,.55))}
    .card-title{font-size:18px;font-weight:700;margin-bottom:10px}
    .card-desc{font-size:13px;line-height:1.6;color:rgba(255,255,255,.5);flex:1;margin-bottom:24px}
    .card-footer{display:flex;align-items:center;justify-content:space-between;gap:10px}
    .card-price{font-size:22px;font-weight:800;background:linear-gradient(135deg,#fff,#a8d8ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .btn-buy{display:flex;align-items:center;gap:6px;background:linear-gradient(135deg,#4aacff,#2b7fff);color:#fff;border:none;border-radius:10px;padding:9px 16px;font-size:13px;font-weight:600;cursor:pointer;font-family:"Inter",sans-serif;transition:all .25s;box-shadow:0 4px 16px rgba(74,172,255,.32)}
    .btn-buy:hover{box-shadow:0 6px 28px rgba(74,172,255,.55);transform:translateY(-1px) scale(1.04)}
    .btn-buy:active{transform:scale(.97)}

    /* ABOUT */
    .about-section{padding:80px 40px;max-width:1100px;margin:0 auto}
    .about-eyebrow{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(74,172,255,.8);margin-bottom:14px;text-align:center}
    .about-title{font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-1.5px;text-align:center;margin-bottom:16px;background:linear-gradient(135deg,#fff 40%,rgba(74,172,255,.85));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .about-sub{font-size:15px;color:rgba(255,255,255,.48);text-align:center;margin-bottom:60px;max-width:560px;margin-left:auto;margin-right:auto}
    .about-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px}
    .about-card{background:rgba(255,255,255,.06);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:28px 24px;transition:border-color .3s,transform .3s,box-shadow .3s;position:relative;overflow:hidden}
    .about-card:hover{border-color:rgba(74,172,255,.38);transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,0,0,.4),0 0 28px rgba(74,172,255,.1)}
    .about-card-icon{font-size:32px;margin-bottom:14px}
    .about-card-title{font-size:16px;font-weight:700;margin-bottom:8px}
    .about-card-text{font-size:13px;line-height:1.65;color:rgba(255,255,255,.48)}

    /* FAQ */
    .faq-section{padding:80px 40px 120px;max-width:800px;margin:0 auto}
    .faq-eyebrow{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(74,172,255,.8);margin-bottom:14px;text-align:center}
    .faq-title{font-size:clamp(26px,4vw,42px);font-weight:800;letter-spacing:-1.2px;text-align:center;margin-bottom:12px;background:linear-gradient(135deg,#fff 40%,rgba(74,172,255,.85));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .faq-sub{font-size:14px;color:rgba(255,255,255,.4);text-align:center;margin-bottom:48px}
    .faq-box{background:rgba(255,255,255,.06);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.1);border-radius:18px;overflow:hidden}
    .faq-row{padding:22px 28px;border-bottom:1px solid rgba(255,255,255,.07);display:flex;justify-content:space-between;align-items:flex-start;gap:16px}
    .faq-row:last-child{border-bottom:none}
    .faq-q{font-size:13.5px;font-weight:700;color:rgba(255,255,255,.75);min-width:140px;flex-shrink:0}
    .faq-a{font-size:13.5px;color:rgba(255,255,255,.5);line-height:1.6;text-align:right}
    .faq-a a{color:#4aacff;text-decoration:none}
    .faq-copyright{text-align:center;margin-top:32px;font-size:12px;color:rgba(255,255,255,.25);line-height:1.7}

    /* MODALS */
    .modal-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.72);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center}
    .modal-box{background:rgba(20,28,50,.42);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border:1px solid rgba(255,255,255,.14);border-radius:22px;padding:38px 34px;width:100%;max-width:400px;position:relative;box-shadow:0 32px 88px rgba(0,0,0,.55),0 0 48px rgba(74,172,255,.1);animation:modalIn .32s cubic-bezier(.34,1.56,.64,1) both}
    .buy-modal-box{background:rgba(7,11,26,.97);border:1px solid rgba(74,172,255,.16);border-radius:22px;padding:32px 30px;width:100%;max-width:480px;position:relative;box-shadow:0 32px 88px rgba(0,0,0,.65),0 0 48px rgba(74,172,255,.08);animation:modalIn .32s cubic-bezier(.34,1.56,.64,1) both}
    @keyframes modalIn{from{transform:scale(.86) translateY(18px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
    .confetti-piece{position:fixed;top:-20px;z-index:9999;pointer-events:none;will-change:transform,opacity;animation:confettiFall linear forwards}
    @keyframes confettiFall{0%{transform:translateY(0) translateX(0) rotate(0deg);opacity:1}100%{transform:translateY(105vh) translateX(var(--dx)) rotate(var(--rot));opacity:0}}
    .prize-card{aspect-ratio:1/1.15;border-radius:14px;background:linear-gradient(135deg,rgba(74,172,255,.14),rgba(74,172,255,.05));border:1px solid rgba(74,172,255,.25);display:flex;align-items:center;justify-content:center;font-size:30px;cursor:pointer;transition:transform .2s,border-color .2s,background .2s;user-select:none}
    .prize-card:hover:not(.disabled){transform:translateY(-4px);border-color:rgba(74,172,255,.55)}
    .prize-card.disabled{opacity:.35;cursor:default;pointer-events:none}
    .prize-card.revealed{background:linear-gradient(135deg,rgba(255,207,107,.18),rgba(255,157,74,.08));border-color:rgba(255,207,107,.5);animation:cardPop .35s ease}
    @keyframes cardPop{0%{transform:scale(.85)}60%{transform:scale(1.08)}100%{transform:scale(1)}}
    .modal-close{position:absolute;top:14px;right:18px;background:none;border:none;color:rgba(255,255,255,.32);font-size:24px;cursor:pointer;line-height:1;transition:color .2s,transform .25s}
    .modal-close:hover{color:#fff;transform:rotate(90deg)}
    .modal-title{font-size:23px;font-weight:800;margin-bottom:6px;background:linear-gradient(135deg,#fff,#a8d8ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .modal-sub{font-size:13px;color:rgba(255,255,255,.38);margin-bottom:28px}
    .field{margin-bottom:16px}
    .field label{display:block;font-size:11px;font-weight:700;color:rgba(74,172,255,.75);margin-bottom:7px;letter-spacing:1px}
    .field input{width:100%;padding:12px 15px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:11px;color:#fff;font-size:14px;font-family:"Inter",sans-serif;outline:none;transition:border-color .2s,box-shadow .2s,background .2s}
    .field input:focus{border-color:rgba(74,172,255,.6);box-shadow:0 0 0 3px rgba(74,172,255,.1);background:rgba(74,172,255,.05)}
    .field input::placeholder{color:rgba(255,255,255,.2)}
    .btn-submit{width:100%;padding:13px;background:linear-gradient(135deg,#4aacff,#2b7fff);color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;margin-top:10px;font-family:"Inter",sans-serif;transition:all .25s;box-shadow:0 4px 22px rgba(74,172,255,.36)}
    .btn-submit:hover{box-shadow:0 6px 32px rgba(74,172,255,.58);transform:translateY(-1px)}
    .modal-switch{text-align:center;margin-top:20px;font-size:13px;color:rgba(255,255,255,.4)}
    .modal-switch a{color:#4aacff;text-decoration:none;cursor:pointer;font-weight:600}
    .error-msg{color:#ff6b6b;font-size:12.5px;margin-top:10px;text-align:center;display:none}
    .success-msg{color:#4dff9b;font-size:12.5px;margin-top:10px;text-align:center;display:none}

    /* BUY MODAL */
    .buy-product-card{background:rgba(74,172,255,.07);border:1px solid rgba(74,172,255,.18);border-radius:14px;padding:18px 20px;display:flex;align-items:center;gap:16px;margin-bottom:24px}
    .buy-product-name{font-size:17px;font-weight:800;margin-bottom:3px}
    .buy-product-desc{font-size:12px;color:rgba(255,255,255,.45);line-height:1.4}
    .promo-row{display:flex;gap:8px;margin-bottom:6px}
    .promo-input{flex:1;padding:11px 14px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;color:#fff;font-size:13.5px;font-family:"Inter",sans-serif;outline:none;transition:border-color .2s}
    .promo-input:focus{border-color:rgba(74,172,255,.55);box-shadow:0 0 0 3px rgba(74,172,255,.1)}
    .promo-input::placeholder{color:rgba(255,255,255,.22)}
    .btn-promo{padding:11px 16px;background:rgba(74,172,255,.15);border:1px solid rgba(74,172,255,.3);border-radius:10px;color:#4aacff;font-size:13px;font-weight:700;cursor:pointer;font-family:"Inter",sans-serif;transition:all .2s;white-space:nowrap}
    .btn-promo:hover{background:rgba(74,172,255,.28)}
    .promo-ok{color:#4dff9b;font-size:12px;font-weight:600;margin-bottom:12px;display:none}
    .promo-err{color:#ff6b6b;font-size:12px;font-weight:600;margin-bottom:12px;display:none}
    .buy-price-block{display:flex;align-items:baseline;gap:10px;margin-bottom:22px}
    .buy-price-final{font-size:28px;font-weight:800;background:linear-gradient(135deg,#fff,#a8d8ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .buy-price-old{font-size:16px;font-weight:600;color:rgba(255,255,255,.3);text-decoration:line-through;display:none}
    .buy-disc-badge{font-size:11px;font-weight:700;background:rgba(77,255,155,.15);border:1px solid rgba(77,255,155,.3);color:#4dff9b;border-radius:6px;padding:3px 8px;display:none}
    .pay-label{font-size:11px;font-weight:700;color:rgba(74,172,255,.75);letter-spacing:1px;margin-bottom:12px}
    .pay-methods{display:flex;gap:10px;margin-bottom:22px}
    .pay-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 10px;background:rgba(255,255,255,.05);border:1.5px solid rgba(255,255,255,.1);border-radius:13px;cursor:pointer;transition:all .25s;font-family:"Inter",sans-serif}
    .pay-btn:hover{background:rgba(74,172,255,.1);border-color:rgba(74,172,255,.35);transform:translateY(-2px)}
    .pay-btn.selected{background:rgba(74,172,255,.14);border-color:#4aacff;box-shadow:0 0 22px rgba(74,172,255,.22)}
    .pay-btn svg{transition:transform .25s,filter .25s}
    .pay-btn:hover svg{transform:scale(1.08)}
    .pay-btn-name{font-size:12px;font-weight:700;color:rgba(255,255,255,.9)}
    .pay-btn-sub{font-size:10px;color:rgba(255,255,255,.38)}
    .btn-confirm{width:100%;padding:14px;background:linear-gradient(135deg,#4aacff,#2b7fff);color:#fff;border:none;border-radius:13px;font-size:15px;font-weight:800;cursor:pointer;font-family:"Inter",sans-serif;transition:all .25s;box-shadow:0 4px 22px rgba(74,172,255,.36)}
    .btn-confirm:hover{box-shadow:0 6px 36px rgba(74,172,255,.6);transform:translateY(-1px)}
    .btn-confirm:disabled{opacity:.4;cursor:not-allowed;transform:none}

    /* PROFILE */
    .profile-content{padding:36px 40px 80px;animation:fadeUp .5s both}
    .back-link{display:inline-flex;align-items:center;gap:7px;color:rgba(255,255,255,.5);font-size:13.5px;font-weight:500;margin-bottom:28px;cursor:pointer;transition:color .2s,gap .2s}
    .back-link:hover{color:#4aacff;gap:11px}
    .profile-eyebrow{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:rgba(74,172,255,.75);margin-bottom:10px}
    .profile-title{font-size:clamp(28px,5vw,46px);font-weight:800;letter-spacing:-1px;margin-bottom:6px;background:linear-gradient(135deg,#fff 40%,rgba(74,172,255,.8));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .profile-sub{font-size:14px;color:rgba(255,255,255,.4);margin-bottom:32px}
    .info-card{background:rgba(255,255,255,.055);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.09);border-radius:18px;overflow:hidden;max-width:900px;box-shadow:0 24px 64px rgba(0,0,0,.32)}
    .info-row{display:flex;justify-content:space-between;align-items:center;padding:20px 28px;border-bottom:1px solid rgba(255,255,255,.06);transition:background .2s}
    .info-row:hover{background:rgba(74,172,255,.05)}
    .info-row:last-child{border-bottom:none}
    .info-label{font-size:14px;color:rgba(255,255,255,.45);font-weight:500}
    .info-value{font-size:14px;font-weight:600}
    .info-value.blue{color:#4aacff;text-shadow:0 0 16px rgba(74,172,255,.4)}
    .info-value.green{color:#4dff9b}
    .btn-logout{margin-top:16px;background:rgba(255,60,60,.09);border:1px solid rgba(255,80,80,.25);color:#ff6b6b;padding:11px 26px;border-radius:11px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:"Inter",sans-serif;transition:all .25s}
    .btn-logout:hover{background:rgba(255,60,60,.2);transform:translateY(-1px)}
    .btn-download{margin-top:16px;margin-left:12px;background:linear-gradient(135deg,#4aacff,#2b7fff);color:#fff;border:none;padding:11px 26px;border-radius:11px;font-size:13.5px;font-weight:700;cursor:pointer;font-family:"Inter",sans-serif;transition:all .25s;box-shadow:0 4px 16px rgba(74,172,255,.3);display:none}
    .btn-neutral{margin-top:16px;margin-left:12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.14);color:#fff;padding:11px 26px;border-radius:11px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:"Inter",sans-serif;transition:all .25s}
    .btn-neutral:hover{border-color:rgba(74,172,255,.4);background:rgba(255,255,255,.08)}
    .btn-download:hover{box-shadow:0 6px 28px rgba(74,172,255,.55);transform:translateY(-1px)}

    /* KEY MODAL */
    .key-modal-box{background:rgba(7,11,26,.97);border:1px solid rgba(74,172,255,.16);border-radius:22px;padding:36px 32px;width:100%;max-width:420px;position:relative;box-shadow:0 32px 88px rgba(0,0,0,.65);animation:modalIn .32s cubic-bezier(.34,1.56,.64,1) both}
    .key-hint{font-size:12px;color:rgba(255,255,255,.3);margin-top:8px;line-height:1.5}

    /* TOAST */
    #toast{display:none;position:fixed;bottom:32px;left:50%;transform:translateX(-50%);z-index:300;padding:13px 26px;border-radius:14px;font-size:14px;font-weight:700;backdrop-filter:blur(10px);box-shadow:0 8px 32px rgba(0,0,0,.4);transition:opacity .5s;white-space:nowrap}
    #toast.ok{background:rgba(77,255,155,.15);border:1px solid rgba(77,255,155,.35);color:#4dff9b}
    #toast.err{background:rgba(255,80,80,.15);border:1px solid rgba(255,80,80,.35);color:#ff6b6b}

    /* AUTH GATE */
    .auth-gate{background:rgba(74,172,255,.08);border:1px solid rgba(74,172,255,.2);border-radius:14px;padding:18px 22px;text-align:center;font-size:13.5px;color:rgba(255,255,255,.55);margin-bottom:24px;display:none}
    .auth-gate a{color:#4aacff;cursor:pointer;font-weight:600}

    @media(max-width:680px){nav{padding:0 16px}.nav-links{display:none}.shop{padding:60px 16px 60px}.card{width:100%;max-width:340px}.profile-content{padding:24px 16px 60px}.about-section,.faq-section{padding:60px 16px}.faq-row{flex-direction:column;gap:6px}.faq-a{text-align:left}}
  </style>
</head>
<body>

<div class="bg-img"></div>
<div class="bg-overlay"></div>
<div class="particles" id="particles"></div>

<!-- ===== SHOP PAGE ===== -->
<div id="shopPage" class="page active">
  <nav>
    <a class="nav-logo" href="#" onclick="goShop();return false;">
