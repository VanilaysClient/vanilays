async function adminGrant(uid, days, label){
  try{
    var ref=doc(db,"users",uid);
    var snap=await getDoc(ref);
    if(!snap.exists()) return;
    var u=snap.data();
    grantSubscription(u,days,label);
    await updateDoc(ref,{hasSub:u.hasSub, subLabel:u.subLabel, subForever:u.subForever, subExpiry:u.subExpiry});
    showToast("✓ Выдана подписка «"+label+"» → "+u.username, "ok");
    openAdminPanel();
  }catch(e){
    showToast("Ошибка доступа","err");
  }
}
async function adminRevoke(uid){
  try{
    var ref=doc(db,"users",uid);
    var snap=await getDoc(ref);
    if(!snap.exists()) return;
    await updateDoc(ref,{hasSub:false,subExpiry:null,subForever:false,subLabel:""});
