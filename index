async function register(){
  var u=document.getElementById("regUsername").value.trim();
  var e=document.getElementById("regEmail").value.trim();
  var p=document.getElementById("regPassword").value;
  var err=document.getElementById("regError");
  if(!u||!e||!p){err.textContent="Заполни все поля";err.style.display="block";return;}
  if(!USERNAME_RE.test(u)){err.textContent="Никнейм: только английские буквы, цифры и _ (3-20 символов)";err.style.display="block";return;}
  if(u.toLowerCase()==="developer"){err.textContent="Этот никнейм зарезервирован";err.style.display="block";return;}
  if(!EMAIL_RE.test(e)){err.textContent="Введи настоящий email (например name@mail.com)";err.style.display="block";return;}
  if(p.length<6){err.textContent="Пароль минимум 6 символов";err.style.display="block";return;}

  var lower=u.toLowerCase();
  var cred;
  try{
    cred=await createUserWithEmailAndPassword(auth,e,p);
  }catch(authErr){
    err.textContent=authErrorToRu(authErr.code);err.style.display="block";return;
  }
  try{
    var batch=writeBatch(db);
    batch.set(doc(db,"usernames",lower),{uid:cred.user.uid,email:e});
    batch.set(doc(db,"users",cred.user.uid),{
      username:u,email:e,regDate:todayStr(),hasSub:false,subLabel:"",subForever:false,
      subExpiry:null,lastPrizeClaim:0,beta:false,banned:false,role:"user"
    });
    await batch.commit();
  }catch(writeErr){
    try{ await cred.user.delete(); }catch(delErr){}
    err.textContent="Никнейм уже занят";err.style.display="block";return;
  }
  closeModal();
}

async function login(){
  var u=document.getElementById("loginUsername").value.trim();
