  try{
    var ref=doc(db,"users",uid);
    var snap=await getDoc(ref);
    if(!snap.exists()) return;
    await updateDoc(ref,{banned:false});
    showToast("✓ "+snap.data().username+" разблокирован", "ok");
    openAdminPanel();
  }catch(e){
    showToast("Ошибка доступа","err");
  }
}
function closeAdminPanel(){document.getElementById("adminModal").style.display="none";}

function isDevUser(u){
  return !!(u && u.role==="dev");
}

function daysLeftFor(u){
  if(u.subForever) return Infinity;
  if(!u.subExpiry) return 0;
  return Math.ceil((u.subExpiry-Date.now())/86400000);
}

function refreshProfile(){
  if(!currentUser) return;
  document.getElementById("profileTitle").textContent=currentUser.username.toUpperCase();
  document.getElementById("pUID").textContent=currentUser.uid;
  document.getElementById("pUsername").textContent=currentUser.username;
  document.getElementById("pEmail").textContent=currentUser.email;
  document.getElementById("pDate").textContent=currentUser.regDate;
  var subEl=document.getElementById("pSub");
  var daysEl=document.getElementById("pDays");
  var dlBtn=document.getElementById("btnDownload");
  var notice=document.getElementById("subNotice");
  var roleEl=document.getElementById("pRole");
  var isDev=isDevUser(currentUser);

  if(isDev){
    roleEl.textContent="DEV";
    roleEl.style.color="#ff3b3b";
    roleEl.style.fontWeight="800";
    roleEl.style.textShadow="0 0 12px rgba(255,59,59,.5)";
  } else {
    roleEl.textContent="USER";
    roleEl.style.color="";
    roleEl.style.fontWeight="";
    roleEl.style.textShadow="";
  }

  // DEV получает полный доступ автоматически, без реальной подписки
  if(isDev){
    subEl.textContent="Полный доступ (DEV)";
    subEl.className="info-value green";
    daysEl.textContent="∞";
    dlBtn.style.display="inline-block";
    notice.style.display="none";
    document.getElementById("btnAdmin").style.display="inline-block";
    document.getElementById("keyMsg").style.display="none";
    document.getElementById("keyInput").value="";
    return;
  }
  document.getElementById("btnAdmin").style.display="none";

  var daysLeft=daysLeftFor(currentUser);
  var justExpired=false;
  if(currentUser.hasSub && !currentUser.subForever && daysLeft<=0){
    // Subscription has run out — expire it
    currentUser.hasSub=false;
    currentUser.subExpiry=null;
    saveCurrentUser();
    justExpired=true;
    notice.style.display="flex";
    notice.style.background="rgba(255,90,90,.1)";
    notice.style.border="1px solid rgba(255,90,90,.3)";
    notice.style.color="#ff8a8a";
    notice.innerHTML=BELL_SVG+"Ваша подписка истекла. Продли доступ, чтобы не потерять функции.";
  }

  if(currentUser.hasSub){
    subEl.textContent=currentUser.subLabel+" — активна";
    subEl.className="info-value green";
    daysEl.textContent=currentUser.subForever?"∞":daysLeft;
    dlBtn.style.display="inline-block";
    if(!currentUser.subForever && daysLeft<=3){
      notice.style.display="flex";
      notice.style.background="rgba(255,190,60,.1)";
      notice.style.border="1px solid rgba(255,190,60,.3)";
      notice.style.color="#ffcf6b";
      notice.innerHTML=BELL_SVG+"Ваша подписка истекает через "+daysLeft+" "+dayWord(daysLeft)+". Не забудь продлить.";
    } else {
      notice.style.display="none";
    }
  } else {
    subEl.textContent="Не активна";
    subEl.className="info-value";
    subEl.style.color="rgba(255,255,255,.35)";
    daysEl.textContent="—";
    dlBtn.style.display="none";
    if(!justExpired) notice.style.display="none";
  }
  document.getElementById("keyMsg").style.display="none";
  document.getElementById("keyInput").value="";
}

function grantSubscription(user,days,label){
  if(days>=999999){
    user.subForever=true;
    user.subExpiry=null;
  } else {
    var base=(user.hasSub && !user.subForever && user.subExpiry && user.subExpiry>Date.now())?user.subExpiry:Date.now();
    user.subExpiry=base+days*86400000;
    user.subForever=false;
  }
  user.hasSub=true;
  user.subLabel=label;
}

// ── KEY ACTIVATION ──
async function activateKey(){
  var raw=document.getElementById("keyInput").value.trim().toUpperCase();
  var msgEl=document.getElementById("keyMsg");
  if(!raw){msgEl.textContent="Введи ключ";msgEl.style.color="#ff6b6b";msgEl.style.display="block";return;}
  var hash=await sha256Hex(raw);
  var k=KEYS[hash];
  if(!k){msgEl.textContent="Неверный ключ";msgEl.style.color="#ff6b6b";msgEl.style.display="block";return;}

  var newFields=null;
  if(k.type!=="hwid"){
    var base=(currentUser.hasSub && !currentUser.subForever && currentUser.subExpiry && currentUser.subExpiry>Date.now())?currentUser.subExpiry:Date.now();
    newFields = k.days>=999999
      ? {hasSub:true, subForever:true, subExpiry:null, subLabel:k.label}
      : {hasSub:true, subForever:false, subExpiry:base+k.days*86400000, subLabel:k.label};
  }

  try{
    await runTransaction(db, async function(tx){
      var usedRef=doc(db,"usedKeys",hash);
      var usedSnap=await tx.get(usedRef);
      if(usedSnap.exists()) throw new Error("used");
      tx.set(usedRef,{usedBy:currentUser.uid, usedAt:Date.now()});
      if(newFields) tx.update(doc(db,"users",currentUser.uid), newFields);
    });
  }catch(txErr){
    msgEl.textContent = txErr.message==="used" ? "Этот ключ уже был использован" : "Ошибка активации, попробуй ещё раз";
    msgEl.style.color="#ff6b6b";msgEl.style.display="block";
    return;
  }

  if(k.type==="hwid"){
    msgEl.innerHTML=CHECK_SVG+"HWID успешно сброшен!";
    msgEl.style.color="#4dff9b";
    msgEl.style.display="block";
    showToast(CHECK_SVG+"HWID сброшен","ok");
  } else {
    Object.assign(currentUser,newFields);
    refreshProfile();
    msgEl.innerHTML=CHECK_SVG+"Подписка «"+k.label+"» активирована!";
    msgEl.style.color="#4dff9b";
    msgEl.style.display="block";
    showToast(CHECK_SVG+"Подписка активирована — "+k.label,"ok");
  }
}

// ── DAILY PRIZE ──
var PRIZE_POOL=[
  {type:"promo30", chance:10, label:"Промокод -30%"},
  {type:"nothing",  chance:25, label:"Ничего"},
  {type:"nothing",  chance:25, label:"Ничего"},
  {type:"day1",     chance:20, label:"+1 день подписки"},
  {type:"sub7",     chance:15, label:"Подписка на 7 дней"},
  {type:"forever",  chance:4,  label:"Подписка навсегда"},
  {type:"beta",     chance:1,  label:"Закрытый бета-тест"}
];
var PRIZE_COOLDOWN_MS=24*60*60*1000;
var prizeInProgress=false;

function rollPrize(){
  var r=Math.random()*100, acc=0;
  for(var i=0;i<PRIZE_POOL.length;i++){
    acc+=PRIZE_POOL[i].chance;
    if(r<=acc) return PRIZE_POOL[i];
  }
  return PRIZE_POOL[PRIZE_POOL.length-1];
}

function genPromoCode(){
  var s="VNL-";
  var chars="ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
  for(var i=0;i<6;i++) s+=chars[Math.floor(Math.random()*chars.length)];
  return s;
}

function openPrizeModal(){
  if(!currentUser) return;
  var now=Date.now();
  var remain=isDevUser(currentUser)?0:PRIZE_COOLDOWN_MS-(now-(currentUser.lastPrizeClaim||0));
  document.getElementById("prizeModal").style.display="flex";
  document.getElementById("prizeResult").style.display="none";
  document.getElementById("prizeCooldown").style.display="none";
  var cardsWrap=document.getElementById("prizeCards");
  cardsWrap.innerHTML="";
  prizeInProgress=false;

  if(remain>0){
    var h=Math.floor(remain/3600000), m=Math.floor((remain%3600000)/60000);
    document.getElementById("prizeCooldown").style.display="block";
    document.getElementById("prizeCooldown").textContent="Следующий приз будет доступен через "+h+" ч "+m+" мин.";
    for(var i=0;i<6;i++){
      var c=document.createElement("div");
      c.className="prize-card disabled";
      c.innerHTML=CARD_BACK_SVG;
      cardsWrap.appendChild(c);
    }
    return;
  }

  for(var j=0;j<6;j++){
    (function(idx){
      var c=document.createElement("div");
      c.className="prize-card";
      c.innerHTML=CARD_BACK_SVG;
      c.onclick=function(){ if(!prizeInProgress) revealPrize(c); };
      cardsWrap.appendChild(c);
    })(j);
  }
}

function closePrizeModal(){document.getElementById("prizeModal").style.display="none";}

async function revealPrize(cardEl){
  prizeInProgress=true;
  document.querySelectorAll("#prizeCards .prize-card").forEach(function(c){c.classList.add("disabled");});
  var prize=rollPrize();
  cardEl.classList.remove("disabled");
  cardEl.classList.add("revealed");
  cardEl.innerHTML=prizeIconSVG(prize.type);
  currentUser.lastPrizeClaim=Date.now();
  applyPrize(prize);
  await saveCurrentUser();
}

